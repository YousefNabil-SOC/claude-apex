# ============================================================
# Claude Apex V7 — Environment Variables Template
# ============================================================
# Copy this file to ~/.claude/.env and fill in your real keys.
# File permissions should be 600 (user-only read/write).
#
#   cp config/env.template ~/.claude/.env
#   chmod 600 ~/.claude/.env
#
# Never commit ~/.claude/.env to a git repo — it's in .gitignore.
# The settings.json template references these as ${VAR_NAME}.
# ============================================================

# ---- REQUIRED for full V7 experience ----

# fal.ai image generation (used by fal-* skills)
# Get a key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_ai_key_here

# GitHub Personal Access Token (used by github MCP server)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, workflow
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Exa web search (used by exa-web-search MCP server)
# Get a key at: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# 21st.dev Magic MCP (premium React component generation)
# Get a key at: https://21st.dev/
TWENTY_FIRST_DEV_API_KEY=your_21st_dev_api_key_here

# ---- OPTIONAL ----

# Testsprite (automated test generation MCP)
# TESTSPRITE_API_KEY=your_testsprite_key_here

# Firecrawl (website scraping MCP)
# FIRECRAWL_API_KEY=your_firecrawl_key_here

# Supabase (database MCP)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic API (only if running the SDK or local agents outside Claude Code)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API (only if using OpenAI in parallel)
# OPENAI_API_KEY=sk-your_openai_key_here

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. Never commit this file with real values filled in
# 2. Never paste these keys into a chat message or issue
# 3. Rotate keys every 90 days or immediately if leaked
# 4. Use minimum-scope tokens (GitHub: repo scope only if private repos)
# 5. Add ~/.claude/.env to .gitignore even for private repos
# ============================================================
